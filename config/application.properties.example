# =============================================================================
# VPS / production — ONE file for shared database + secrets (all 3 services)
# Copy to: /etc/flintnthread/application.properties
# Or set FLINT_CONFIG_DIR to folder containing this file
# =============================================================================

SPRING_PROFILES_ACTIVE=prod

# --- ONE database (user + seller + admin all use this) ---
DB_URL=jdbc:mysql://127.0.0.1:3306/flintandthread?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Kolkata
DB_USERNAME=root
DB_PASSWORD=YOUR_MYSQL_PASSWORD

# --- Service ports ---
USER_SERVICE_PORT=8080
SELLER_SERVICE_PORT=8083
ADMIN_SERVICE_PORT=8082

# --- Mail ---
SENDGRID_API_KEY=SG.your-sendgrid-key
MAIL_FROM=support@flintnthread.in

# --- Payment / logistics ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# --- SMS ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- JWT ---
SELLER_JWT_SECRET=your-seller-jwt-secret-min-32-chars
ADMIN_JWT_SECRET=your-admin-jwt-secret-min-32-chars

# --- Other ---
GST_LOOKUP_API_KEY=
MEDIA_PUBLIC_BASE_URL=https://flintnthread.in
APP_BACKEND_PUBLIC_URL=https://flintnthread.online
APP_FRONTEND_BASE_URL=https://your-seller-app-url
ADMIN_FRONTEND_URL=https://your-admin-url
ADMIN_CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006,https://flintnthread.online,https://www.flintnthread.online
